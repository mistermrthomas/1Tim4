# Copy to .env.local for local dev. Add the same keys in Vercel → Settings → Environment Variables.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Optional: AI intake guidance (server-side only — set OPENAI_API_KEY in Vercel, not VITE_)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# VITE_ASSESSMENT_AI=false
# VITE_GO_DEEPER_AI=false
