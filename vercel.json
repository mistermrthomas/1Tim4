{
  "functions": {
    "api/assessment-plan.ts": {
      "maxDuration": 30
    },
    "api/go-deeper.ts": {
      "maxDuration": 30
    },
    "api/reading-questions.ts": {
      "maxDuration": 30
    },
    "api/push-subscribe.ts": {
      "maxDuration": 15
    },
    "api/cron/reminders.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "*/15 * * * *"
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
